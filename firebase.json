{
  "functions": {
    "source": ".output/server"
  },
  "hosting": {
    "public": ".output/public",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "server",
          "region": "us-central1"
        }
      }
    ]
  }
}
